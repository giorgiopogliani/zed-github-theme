amends "config/theme.pkl"

import "config/colors.pkl"

name = "Github Inspired Theme"

author = "Giorgio Pogliani"

themes = new Listing {
  new Theme {
    name = "My Github Dark v2"
    appearance = "dark"
    style {
      border = colors.githubDark.borderMuted
      `border.variant` = colors.githubDark.borderMuted
      `border.focused` = colors.githubDark.accentMuted
      `border.selected` = colors.githubDark.border
      `border.transparent` = colors.githubDark.canvas + "00"
      `border.disabled` = colors.githubDark.borderMuted
      `elevated_surface.background` = colors.githubDark.elevated
      `surface.background` = colors.githubDark.canvasSubtle
      background = colors.githubDark.canvas
      `element.background` = colors.githubDark.canvasSubtle
      `element.hover` = colors.githubDark.elevated
      `element.active` = colors.githubDark.overlay
      `element.selected` = colors.githubDark.elevated
      `element.disabled` = colors.githubDark.canvasSubtle + "80"
      `drop_target.background` = colors.githubDark.accentMuted + "44"
      `ghost_element.background` = null
      `ghost_element.hover` = colors.githubDark.elevated + "99"
      `ghost_element.active` = colors.githubDark.overlay + "99"
      `ghost_element.selected` = colors.githubDark.overlay + "99"
      `ghost_element.disabled` = null
      text = colors.githubDark.fg
      `text.muted` = colors.githubDark.fgMuted
      `text.placeholder` = colors.githubDark.fgSubtle
      `text.disabled` = colors.githubDark.fgDisabled
      `text.accent` = colors.githubDark.accent
      icon = colors.githubDark.fgMuted
      `icon.muted` = colors.githubDark.fgSubtle
      `icon.disabled` = colors.githubDark.fgDisabled
      `icon.placeholder` = colors.githubDark.fgSubtle
      `icon.accent` = colors.githubDark.accent
      `title_bar.background` = colors.githubDark.canvasSubtle
      `status_bar.background` = colors.githubDark.canvasSubtle
      `tab_bar.background` = colors.githubDark.canvas
      `tab.inactive_background` = colors.githubDark.canvas
      `toolbar.background` = colors.githubDark.canvasSubtle
      `tab.active_background` = colors.githubDark.canvasSubtle
      `search.match_background` = colors.githubDark.warningDark + "66"
      `panel.background` = colors.githubDark.canvasSubtle
      `panel.focused_border` = colors.githubDark.border
      `pane_group.border` = colors.githubDark.borderMuted
      `scrollbar_thumb.background` = colors.githubDark.overlay
      `scrollbar.thumb.hover_background` = colors.githubDark.fgSubtle + "55"
      `scrollbar.thumb.border` = colors.githubDark.canvasSubtle
      `scrollbar.track.background` = colors.githubDark.canvas
      `scrollbar.track.border` = colors.githubDark.borderMuted
      error = colors.githubDark.danger
      `error.background` = colors.githubDark.dangerDark + "44"
      `error.border` = colors.githubDark.dangerDark + "66"
      warning = colors.githubDark.warning
      `warning.background` = colors.githubDark.warningDark + "44"
      `warning.border` = colors.githubDark.warningDark + "66"
      `editor.background` = colors.githubDark.canvas
      `editor.foreground` = colors.githubDark.fg
      `editor.gutter.background` = colors.githubDark.canvasSubtle
      `editor.subheader.background` = colors.githubDark.canvasSubtle
      `editor.active_line.background` = colors.githubDark.elevated + "99"
      `editor.highlighted_line.background` = colors.githubDark.warningDark + "33"
      `editor.line_number` = colors.githubDark.fgSubtle
      `editor.active_line_number` = colors.githubDark.fg
      `editor.invisible` = colors.githubDark.border
      `editor.wrap_guide` = colors.githubDark.borderMuted
      `editor.active_wrap_guide` = colors.githubDark.overlay
      `editor.document_highlight.read_background` = colors.githubDark.warningDark + "33"
      `editor.document_highlight.write_background` = colors.githubDark.warningDark + "44"
      `terminal.background` = colors.githubDark.canvasSubtle
      `terminal.foreground` = colors.githubDark.fg
      `terminal.bright_foreground` = colors.white
      `terminal.dim_foreground` = colors.githubDark.fgSubtle
      `terminal.ansi.black` = colors.githubDark.canvasInset
      `terminal.ansi.red` = colors.githubDark.danger
      `terminal.ansi.green` = colors.githubDark.success
      `terminal.ansi.yellow` = colors.githubDark.warning
      `terminal.ansi.blue` = colors.githubDark.accent
      `terminal.ansi.magenta` = colors.githubDark.done
      `terminal.ansi.cyan` = colors.githubDark.cyan
      `terminal.ansi.white` = colors.githubDark.fg
      `terminal.ansi.bright_black` = colors.githubDark.fgSubtle
      `terminal.ansi.bright_red` = colors.lighten(colors.githubDark.danger, 10.0)
      `terminal.ansi.bright_green` = colors.lighten(colors.githubDark.success, 15.0)
      `terminal.ansi.bright_yellow` = colors.lighten(colors.githubDark.warning, 15.0)
      `terminal.ansi.bright_blue` = colors.lighten(colors.githubDark.accent, 10.0)
      `terminal.ansi.bright_magenta` = colors.lighten(colors.githubDark.done, 8.0)
      `terminal.ansi.bright_cyan` = colors.lighten(colors.githubDark.cyan, 10.0)
      `terminal.ansi.bright_white` = colors.white
      `link_text.hover` = colors.githubDark.accent
      `hidden` = colors.githubDark.fgDisabled + "66"
      hint = colors.githubDark.fgSubtle
      `hint.background` = colors.githubDark.accentMuted + "44"
      `hint.border` = colors.githubDark.accentMuted + "66"
      ignored = colors.githubDark.fgDisabled + "66"
      modified = colors.githubDark.accent + "88"
      conflict = colors.githubDark.warning + "88"
      created = colors.githubDark.success + "88"
      deleted = colors.githubDark.danger + "88"
      `predictive.background` = colors.githubDark.overlay
      syntax {
        comment {
          color = colors.githubDark.fgSubtle
          font_style = null
          font_weight = null
        }
        number {
          color = colors.githubDark.accent
          font_style = null
          font_weight = null
        }
        builtin {
          color = colors.githubDark.danger
        }
        string {
          color = colors.githubDark.string
          font_style = null
          font_weight = null
        }
        `function` {
          color = colors.githubDark.done
          font_style = null
          font_weight = null
        }
        symbols {
          color = colors.githubDark.string
        }
        keyword {
          color = colors.githubDark.danger
        }
        tag {
          color = colors.githubDark.danger
        }
        punctuation {
          color = colors.githubDark.fgMuted
          font_style = null
          font_weight = null
        }
        `punctuation.delimiter` {
          color = colors.githubDark.fg
          font_style = null
          font_weight = null
        }
        label {
          color = colors.githubDark.danger
          font_style = null
          font_weight = null
        }
        boolean {
          color = colors.githubDark.accent
          font_style = null
          font_weight = null
        }
        operator {
          color = colors.githubDark.danger
          font_style = null
          font_weight = null
        }
        property {
          color = colors.lighten(colors.githubDark.success, 20.0)
          font_style = null
          font_weight = null
        }
        variable {
          color = colors.githubDark.fg
          font_style = null
          font_weight = null
        }
        constant {
          color = colors.githubDark.accent
          font_style = null
          font_weight = null
        }
        type {
          color = colors.githubDark.orange
          font_style = null
          font_weight = null
        }
        constructor {
          color = colors.githubDark.orange
        }
      }
      players = new Listing {
        new PlayerColor {
          cursor = colors.githubDark.accent
          selection = colors.githubDark.selection
          background = colors.githubDark.elevated + "99"
        }
      }
    }
  }
}
